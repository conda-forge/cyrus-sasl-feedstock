From 44b786444a300ff015a8356208cc4e83db8c60a5 Mon Sep 17 00:00:00 2001
From: shadow_walker <shadowwalkersb@gmail.com>
Date: Sun, 10 Jan 2021 13:27:45 -0600
Subject: [PATCH 1/6] patch for osx arm migration

Avoid compile-test on wrong platform by telling autoconf's AC_TRY_RUN to
assume it's there (through its third argument `action-if-cross-compiling`).

See https://www.gnu.org/savannah-checkouts/gnu/autoconf/manual/autoconf-2.72/autoconf.html

Co-Authored-By: H. Vetinari <h.vetinari@gmx.com>
---
 m4/sasl2.m4 | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/m4/sasl2.m4 b/m4/sasl2.m4
index 80371ef0..10e6ddc5 100644
--- a/m4/sasl2.m4
+++ b/m4/sasl2.m4
@@ -337,7 +337,7 @@ int main(void)
 
     return (!have_spnego);  // 0 = success, 1 = failure
 }
-],[ac_cv_gssapi_supports_spnego=yes],[ac_cv_gssapi_supports_spnego=no])
+],[ac_cv_gssapi_supports_spnego=yes],[ac_cv_gssapi_supports_spnego=no],[ac_cv_gssapi_supports_spnego=yes])
     LIBS="$cmu_save_LIBS"
   ])
   AS_IF([test "$ac_cv_gssapi_supports_spnego" = yes],[
